---
import Footer from '../components/Footer.astro';
import MemoryBackground from '../components/MemoryBackground.astro';

interface Props {
  title: string
  channel?: string
  model?: string
  date?: string
  messageCount?: number
}

const { title, channel, model, date, messageCount } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${model} Chats Share - ${title}`} />
    <title>{title} | chats-share</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #141414;
        --bg-tertiary: #1a1a1a;
        --text-primary: #e8e6e3;
        --text-secondary: #8a8785;
        --text-muted: #5c5958;
        --accent: #d4a853;
        --accent-dim: #8b7038;
        --border: #2a2a2a;
        --glow: rgba(212, 168, 83, 0.15);
        --user-msg-bg: #0f0f0f;
        --user-msg-border: #2d2d2d;
        --assistant-msg-bg: #121212;
        --assistant-msg-border: #252525;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg-primary);
      }

      body {
        margin: 0;
        font-family: 'Libre Baskerville', Georgia, serif;
        color: var(--text-primary);
        line-height: 1.6;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      /* Scanline texture */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.03) 2px,
          rgba(0, 0, 0, 0.03) 4px
        );
        z-index: 9999;
      }

      .layout-container {
        max-width: 720px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      /* Header */
      .layout-header-wrapper {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
      }

      .layout-header-title {
        font-size: 1.75rem;
        font-weight: 400;
        color: var(--text-primary);
        margin-bottom: 1rem;
        line-height: 1.4;
      }

      .layout-meta {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .layout-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
      }

      .meta-label {
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.625rem;
      }

      .layout-meta-separator {
        color: var(--border);
        font-size: 0.5rem;
      }

      /* Decorative corners */
      .corner-mark {
        position: fixed;
        width: 12px;
        height: 12px;
        border: 1px solid var(--accent-dim);
        opacity: 0.4;
      }
      .corner-mark.top-left { top: 1rem; left: 1rem; border-right: none; border-bottom: none; }
      .corner-mark.top-right { top: 1rem; right: 1rem; border-left: none; border-bottom: none; }
      .corner-mark.bottom-left { bottom: 1rem; left: 1rem; border-right: none; border-top: none; }
      .corner-mark.bottom-right { bottom: 1rem; right: 1rem; border-left: none; border-top: none; }
    </style>
  </head>
  <body>
    <MemoryBackground />

    <!-- Decorative corners -->
    <div class="corner-mark top-left"></div>
    <div class="corner-mark top-right"></div>
    <div class="corner-mark bottom-left"></div>
    <div class="corner-mark bottom-right"></div>

    <div class="layout-container">
      <div class="layout-header-wrapper">
        <header class="layout-header-title">{title}</header>
        <p class="layout-meta">
          {channel && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">channel</span>
                <span>{channel}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          {model && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">model</span>
                <span>{model}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          <span class="layout-meta-item">
            <span class="meta-label">date</span>
            <span>{date}</span>
          </span>
          <span class="layout-meta-separator">◆</span>
          <span class="layout-meta-item">
            <span class="meta-label">msgs</span>
            <span>{messageCount}</span>
          </span>
        </p>
      </div>

      <main>
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
