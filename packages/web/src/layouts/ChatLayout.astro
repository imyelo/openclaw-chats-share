---
import Footer from '../components/Footer.astro';
import MemoryBackground from '../components/MemoryBackground.astro';
import '../styles/global.css';

interface Props {
  title: string
  channel?: string
  model?: string
  date?: string
  messageCount?: number
}

const { title, channel, model, date, messageCount } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${model} Chats Share - ${title}`} />
    <title>{title} | chats-share</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
      .layout-container {
        max-width: 720px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      /* Header */
      .layout-header-wrapper {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
      }

      .layout-header-title {
        font-size: 1.75rem;
        font-weight: 400;
        color: var(--text-primary);
        margin-bottom: 1rem;
        line-height: 1.4;
      }

      .layout-meta {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .layout-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
      }

      .meta-label {
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.625rem;
      }

      .layout-meta-separator {
        color: var(--border);
        font-size: 0.5rem;
      }

      /* Decorative corners */
      .corner-mark {
        position: fixed;
        width: 12px;
        height: 12px;
        border: 1px solid var(--accent-dim);
        opacity: 0.4;
      }
      .corner-mark.top-left { top: 1rem; left: 1rem; border-right: none; border-bottom: none; }
      .corner-mark.top-right { top: 1rem; right: 1rem; border-left: none; border-bottom: none; }
      .corner-mark.bottom-left { bottom: 1rem; left: 1rem; border-right: none; border-top: none; }
      .corner-mark.bottom-right { bottom: 1rem; right: 1rem; border-left: none; border-top: none; }
    </style>
  </head>
  <body>
    <MemoryBackground />

    <!-- Decorative corners -->
    <div class="corner-mark top-left"></div>
    <div class="corner-mark top-right"></div>
    <div class="corner-mark bottom-left"></div>
    <div class="corner-mark bottom-right"></div>

    <div class="layout-container">
      <div class="layout-header-wrapper">
        <header class="layout-header-title">{title}</header>
        <p class="layout-meta">
          {channel && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">channel</span>
                <span>{channel}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          {model && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">model</span>
                <span>{model}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          <span class="layout-meta-item">
            <span class="meta-label">date</span>
            <span>{date}</span>
          </span>
          <span class="layout-meta-separator">◆</span>
          <span class="layout-meta-item">
            <span class="meta-label">msgs</span>
            <span>{messageCount}</span>
          </span>
        </p>
      </div>

      <main>
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
