---
import Footer from '../components/Footer.astro';
import MemoryBackground from '../components/MemoryBackground.astro';
import DecorativeCorners from '../components/DecorativeCorners.astro';
import '../styles/global.css';

interface Props {
  title: string
  channel?: string
  model?: string
  date?: string
  messageCount?: number
  regularMessageCount?: number
  showProcessByDefault?: boolean
}

const { title, channel, model, date, messageCount, regularMessageCount, showProcessByDefault = false } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${model} Chats Share - ${title}`} />
    <title>{title} | chats-share</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
      .layout-container {
        max-width: 720px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      /* Header */
      .layout-header-wrapper {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
      }

      .layout-header-title {
        font-size: 1.75rem;
        font-weight: 400;
        color: var(--text-primary);
        margin-bottom: 1rem;
        line-height: 1.4;
      }

      .layout-meta {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .layout-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
      }

      .meta-label {
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.625rem;
      }

      .layout-meta-separator {
        color: var(--border);
        font-size: 0.5rem;
      }

      /* Page nav */
      .page-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        color: var(--text-muted);
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.625rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0.8;
        transition: color 0.15s ease, opacity 0.15s ease;
      }

      .back-link:hover {
        color: var(--text-primary);
        opacity: 1;
      }

    </style>
  </head>
  <body class:list={[showProcessByDefault && 'show-process']}>
    <MemoryBackground />
    <DecorativeCorners />

    <div class="layout-container">
      <nav class="page-nav">
        <a href="/" class="back-link">
          <span aria-hidden="true">←</span> archive
        </a>
        <slot name="controls" />
      </nav>

      <div class="layout-header-wrapper">
        <header class="layout-header-title">{title}</header>
        <p class="layout-meta">
          {channel && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">channel</span>
                <span>{channel}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          {model && (
            <>
              <span class="layout-meta-item">
                <span class="meta-label">model</span>
                <span>{model}</span>
              </span>
              <span class="layout-meta-separator">◆</span>
            </>
          )}
          <span class="layout-meta-item">
            <span class="meta-label">date</span>
            <span>{date}</span>
          </span>
          <span class="layout-meta-separator">◆</span>
          <span class="layout-meta-item">
            <span class="meta-label">msgs</span>
            <span>{regularMessageCount} / {messageCount}</span>
          </span>
        </p>
      </div>

      <main>
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
