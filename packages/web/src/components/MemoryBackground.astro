---
// MemoryBackground.astro - Blurred, flowing background effect like fleeting memories
---

<div class="memory-bg">
  <div class="memory-orb" style="width: 55vw; height: 55vw; background: rgba(180, 140, 100, 0.12); top: -15%; left: -10%;"></div>
  <div class="memory-orb" style="width: 45vw; height: 45vw; background: rgba(140, 100, 160, 0.1); top: 35%; right: -12%; animation-delay: -7s;"></div>
  <div class="memory-orb" style="width: 40vw; height: 40vw; background: rgba(100, 130, 170, 0.08); bottom: -15%; left: 25%; animation-delay: -14s;"></div>
  <div class="memory-orb" style="width: 30vw; height: 30vw; background: rgba(160, 130, 110, 0.07); top: 55%; left: -5%; animation-delay: -10s;"></div>
</div>

<style>
  .memory-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .memory-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: float 25s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(6%, 4%) scale(1.06);
    }
    50% {
      transform: translate(-4%, 10%) scale(0.97);
    }
    75% {
      transform: translate(-10%, -3%) scale(1.03);
    }
  }
</style>
