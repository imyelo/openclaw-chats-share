---
import { AVATAR_COLORS, CSS_CLASSES } from '../constants/index.js'
import dayjs from 'dayjs'

interface Props {
  author?: string
  timestamp?: string
  isFirstInGroup?: boolean
  avatarColorIndex?: number
}

const { author, timestamp, isFirstInGroup, avatarColorIndex } = Astro.props

const authorLower = (author ?? '').toLowerCase()
const isAgent = authorLower.includes('agent')

let avatarBg: string | undefined
let avatarColor: string | undefined
if (avatarColorIndex !== undefined) {
  const avatarStyle = AVATAR_COLORS[avatarColorIndex % AVATAR_COLORS.length]
  avatarBg = avatarStyle.bg
  avatarColor = avatarStyle.text
}
---

{author && timestamp && (
  <div class:list={['message-header', !isFirstInGroup && CSS_CLASSES.hiddenHeader]} data-header="true">
    <div
      class:list={['avatar', isAgent ? 'avatar-agent' : 'avatar-human']}
      style={avatarBg ? `background-color: ${avatarBg}; color: ${avatarColor}` : undefined}
    >
      {author.charAt(0).toUpperCase()}
    </div>
    <span class="author-name">{author}</span>
    <span class="author-timestamp" title={timestamp}>
      {dayjs(timestamp).format('HH:mm')}
    </span>
  </div>
)}

<style>
  .hidden-header {
    display: none !important;
  }
  .message-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-inline: 0.25rem;
    margin-bottom: 0.75rem;
    margin-top: 1.25rem;
  }

  .avatar {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .avatar-agent {
    background-color: var(--bg-tertiary);
    color: var(--accent);
    box-shadow: 0 0 0 1px var(--border);
  }

  .avatar-human {
    box-shadow: 0 0 0 1px var(--border);
  }

  .author-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
  }

  .author-timestamp {
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: -0.025em;
  }
</style>
