---
import ChatLayout from '../../layouts/ChatLayout.astro';
import ChatMessage from '../../components/ChatMessage.astro';
import { CollapsibleMessage } from '../../components/CollapsibleMessage';
import { AVATAR_COLORS } from '../../constants/index.js';
import { getAllChatsWithContent, type ChatWithContent } from '../../lib/chats';

export async function getStaticPaths() {
  return (await getAllChatsWithContent()).map(chat => ({
    params: { slug: chat.slug },
    props: { chat },
  }));
}

interface Props {
  chat: ChatWithContent;
}

const { chat } = Astro.props;
const { title, channel, model, date, totalMessages, messageBlocks, participants, defaultShowProcess = false } = chat;
const displayTitle = title || '';

// Determine if process messages should be shown by default based on frontmatter
// defaultShowProcess: true -> show by default (collapsed: false)
// defaultShowProcess: false/undefined -> hide by default (collapsed: true)
const showProcessByDefault = defaultShowProcess;

// Resolve whether a participant name is an agent.
// Checks the frontmatter participants map first; falls back to keyword heuristic.
function isSpeakerAgent(author: string): boolean {
  if (participants && author in participants) {
    return participants[author].role === 'agent';
  }
  const lower = author.toLowerCase();
  return lower.includes('agent') || lower.includes('assistant');
}

// Flatten ParsedMessageBlock[] into a renderable list
const messages = messageBlocks.flatMap(block => {
  const isUser = !isSpeakerAgent(block.author);
  return block.segments.map(seg => ({ ...seg, author: block.author, timestamp: block.timestamp, isUser }));
});

const hasProcessMessages = messages.some((msg: any) => msg.kind === 'directive');
const regularMessageCount = messages.filter((msg: any) => msg.kind !== 'directive').length;

// Create avatar color mapping for unique human authors
const authorColorMap = new Map<string, number>();
let colorIndex = 0;
messages.forEach((msg: any) => {
  if (!isSpeakerAgent(msg.author) && !authorColorMap.has(msg.author)) {
    authorColorMap.set(msg.author, colorIndex % AVATAR_COLORS.length);
    colorIndex++;
  }
});
---

<!-- Pass defaultShowProcess to client-side script via data attribute -->
<script is:inline>
  document.body.dataset.showProcessByDefault = String(!!{showProcessByDefault});
</script>

<ChatLayout
  title={displayTitle}
  channel={channel}
  model={model}
  date={date}
  messageCount={totalMessages}
  regularMessageCount={regularMessageCount}
>
  {hasProcessMessages && (
    <button slot="controls" id="toggle-collapsible-btn" class="toggle-btn" aria-label="Show process information" aria-pressed={String(!showProcessByDefault)}>
      <span class="toggle-pip" aria-hidden="true"></span>
      <span class="toggle-text">show process</span>
    </button>
  )}

  {messages.map((msg: any, index: number) => {
    const isFirstInGroup = index === 0 || messages[index - 1].author !== msg.author;
    const isLastInGroup = index === messages.length - 1 || messages[index + 1].author !== msg.author;

    if (msg.kind === 'directive') {
      const avatarColorIndex = isSpeakerAgent(msg.author) ? undefined : authorColorMap.get(msg.author);
      return (
        <CollapsibleMessage
          client:load
          type={msg.type}
          icon={msg.icon}
          label={msg.label}
          collapsed={msg.collapsed ?? !showProcessByDefault}
          content={msg.content}
          author={msg.author}
          timestamp={msg.timestamp}
          isFirstInGroup={isFirstInGroup}
          isLastInGroup={isLastInGroup}
          avatarColorIndex={avatarColorIndex}
        />
      );
    }

    const avatarColorIndex = isSpeakerAgent(msg.author) ? undefined : authorColorMap.get(msg.author);
    return (
      <ChatMessage
        author={msg.author}
        timestamp={msg.timestamp}
        content={msg.content}
        isUser={msg.isUser}
        isFirstInGroup={isFirstInGroup}
        isLastInGroup={isLastInGroup}
        avatarColorIndex={avatarColorIndex}
      />
    );
  })}

</ChatLayout>

<style>
  /* ── Terminal LED toggle ───────────────────────────────── */

  .toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3125rem 0.625rem 0.3125rem 0.5rem;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  /* Amber wash on hover */
  .toggle-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(212, 168, 83, 0.06) 50%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .toggle-btn:hover::before { opacity: 1; }

  .toggle-btn:hover {
    border-color: var(--accent-dim);
    color: var(--text-secondary);
    box-shadow:
      0 0 10px rgba(212, 168, 83, 0.1),
      inset 0 0 6px rgba(212, 168, 83, 0.03);
  }

  /* When process is hidden: mute the button */
  .toggle-btn[aria-pressed="true"] {
    color: var(--text-muted);
    border-color: var(--border);
  }

  /* LED pip */
  .toggle-pip {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--accent);
    box-shadow:
      0 0 3px var(--accent),
      0 0 7px rgba(212, 168, 83, 0.5);
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  /* Pip dims when process is hidden */
  .toggle-btn[aria-pressed="true"] .toggle-pip {
    background: var(--text-muted);
    box-shadow: none;
  }

  /* CRT-flicker on toggle */
  @keyframes crt-flicker {
    0%   { opacity: 1;    }
    20%  { opacity: 0.25; }
    40%  { opacity: 0.85; }
    60%  { opacity: 0.15; }
    80%  { opacity: 0.75; }
    100% { opacity: 1;    }
  }

  .toggle-btn.is-flickering {
    animation: crt-flicker 0.18s steps(4, jump-none);
  }
</style>

<script>
  function updateHeadersVisibility(isHidden: boolean) {
    // Select all messages in order
    const articles = document.querySelectorAll('article[data-author]');
    let lastVisibleAuthor: string | null = null;

    articles.forEach((article) => {
      // Check if this article is currently hidden by our global class
      const isCollapsible = article.classList.contains('global-collapsible-message');
      const isArticleHidden = isHidden && isCollapsible;

      const header = article.querySelector('[data-header="true"]');
      if (!header) return;

      if (isArticleHidden) {
        // It's hidden, don't update lastVisibleAuthor
        return;
      }

      const author = article.getAttribute('data-author');

      if (author !== lastVisibleAuthor) {
        // This is the first visible message for this author, show header
        header.classList.remove('hidden-header');
        article.classList.remove('not-first-in-group');
      } else {
        // Same author as previous visible message, hide header
        header.classList.add('hidden-header');
        article.classList.add('not-first-in-group');
      }

      lastVisibleAuthor = author;
    });
  }

  function setBtnState(btn: HTMLElement, isHidden: boolean) {
    const label = isHidden ? 'Show process information' : 'Hide process information';
    btn.setAttribute('aria-label', label);
    btn.setAttribute('aria-pressed', String(isHidden));
    const textEl = btn.querySelector('.toggle-text');
    if (textEl) { textEl.textContent = isHidden ? 'show process' : 'hide process'; }
  }

  // Animated batch hide/show for collapsible process messages.
  // display:none cannot be transitioned, so we drive visibility through inline
  // styles: fade-out → display:none when hiding, display:'' → fade-in when showing.
  function animateCollapsibles(show: boolean) {
    const items = document.querySelectorAll<HTMLElement>('.global-collapsible-message');
    if (show) {
      // Reveal elements at opacity 0, then animate to 1.
      items.forEach(el => {
        el.style.display = '';
        el.style.opacity = '0';
      });
      // Double rAF ensures the browser has painted the display:'' state
      // before starting the transition (avoids the transition being skipped).
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          items.forEach(el => {
            el.style.transition = 'opacity 0.2s ease';
            el.style.opacity = '';
          });
          setTimeout(() => {
            items.forEach(el => { el.style.transition = ''; });
          }, 220);
        });
      });
    } else {
      // Fade out, then collapse with display:none.
      items.forEach(el => {
        el.style.transition = 'opacity 0.12s ease';
        el.style.opacity = '0';
      });
      setTimeout(() => {
        items.forEach(el => {
          el.style.display = 'none';
          el.style.opacity = '';
          el.style.transition = '';
        });
      }, 130);
    }
  }

  function setupToggle() {
    const btn = document.getElementById('toggle-collapsible-btn');
    if (!btn) return;

    // Check frontmatter defaultShowProcess setting
    const showProcessByDefault = document.body.dataset.showProcessByDefault === 'true';

    // Default: process messages are hidden unless showProcessByDefault is true
    // Add the class if not already present and not showing by default
    // (it may already be set if the user toggled during this tab session).
    const shouldHide = !showProcessByDefault;
    if (shouldHide && !document.body.classList.contains('hide-collapsible-messages')) {
      document.body.classList.add('hide-collapsible-messages');
    }

    // Show or hide all collapsibles based on the default setting
    document.querySelectorAll('.global-collapsible-message').forEach(el => {
      (el as HTMLElement).style.display = shouldHide ? 'none' : '';
    });

    setBtnState(btn, shouldHide);
    updateHeadersVisibility(shouldHide);

    btn.addEventListener('click', () => {
      document.body.classList.toggle('hide-collapsible-messages');
      const isHidden = document.body.classList.contains('hide-collapsible-messages');

      // CRT flicker effect on toggle
      btn.classList.add('is-flickering');
      btn.addEventListener('animationend', () => btn.classList.remove('is-flickering'), { once: true });

      setBtnState(btn, isHidden);
      updateHeadersVisibility(isHidden);
      animateCollapsibles(!isHidden);
    });
  }

  // Module scripts are deferred and run after the DOM is ready.
  // astro:page-load only fires when View Transitions (ClientRouter) are enabled,
  // so we call setupToggle() directly here instead.
  setupToggle();
</script>
